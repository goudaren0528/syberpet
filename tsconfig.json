{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["renderer/*"],
      "@shared/*": ["shared/*"],
      "@agent/*": ["agent/*"]
    }
  },
  "include": ["electron/**/*", "renderer/**/*", "agent/**/*", "shared/**/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
